# SportBuddy — example environment file.
# Copy to `.env` and fill in REAL values. NEVER commit `.env`.
#
# Spring reads these via ${...} placeholders in application.properties.

# --- Database (Spring datasource) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/sportbuddy
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change-me

# --- PostgreSQL container (docker-compose "db" service) ---
POSTGRES_DB=sportbuddy
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# --- Mail (Gmail SMTP) ---
SPRING_MAIL_USERNAME=your-email@gmail.com
SPRING_MAIL_PASSWORD=your-gmail-app-password

# --- GigaChat (Sber) gRPC client ---
GIGACHAT_AUTHORIZATION_KEY=
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
